# ─────────────────────────────────────────────────────────────────────────────
# x402 Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# OPTIONAL: URL of the deployed x402 payment server.
#
# Local development:
#   Leave unset — the Vite dev server automatically proxies requests whose
#   path starts with /premium or /health to http://localhost:4021
#   (start x402-server first).
#
#   Or set VITE_SERVER_URL to point directly at the deployed Railway server:
#     VITE_SERVER_URL=https://x402-poc-production-ad71.up.railway.app
#
# Production (e.g. Vercel):
#   Set this to your Railway (or other) server URL in your hosting dashboard's
#   Environment Variables section so the build embeds the correct URL.
#   Example:
#     VITE_SERVER_URL=https://x402-poc-production-ad71.up.railway.app
#

VITE_SERVER_URL=https://x402-poc-production-ad71.up.railway.app
